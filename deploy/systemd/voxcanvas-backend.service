[Unit]
Description=VoxCanvas backend service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/voxcanvas/backend
Environment=PORT=6060
Environment=LOG_DIR=/var/log/voxcanvas
Environment=LOG_FILE=voxcanvas-backend.log
EnvironmentFile=-/etc/voxcanvas/backend.env
ExecStart=/opt/voxcanvas/backend/voxcanvas-backend
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
